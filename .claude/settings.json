{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(file:*)",
      "Bash(curl -sI:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(cmd.exe /c \"netstat:*)",
      "Bash(cmd.exe /c \"tasklist:*)",
      "Bash(cmd.exe /c \"dir:*)",
      "Bash(cmd.exe /c \"where:*)"
    ]
  }
}
